---
/** Site footer with copyright and optional address (from original longtex.co.th). */
interface Props {
	/** Copyright line; use YEAR for current year (e.g. "© YEAR Longtex Rubber Industry Co., Ltd.") */
	copyright?: string;
	/** Optional address lines (e.g. Thailand address) */
	address?: string;
}

const { copyright = "© YEAR Longtex Rubber Industry Co., Ltd.", address } = Astro.props;
const year = new Date().getFullYear();
const copyrightText = copyright.replace("YEAR", String(year));
---

<footer class="border-t border-white/10 bg-white/5 px-6 py-8">
	<div class="mx-auto max-w-[800px] text-center">
		<p class="m-0 text-sm text-muted">
			{copyrightText}
		</p>
		{address && (
			<p class="mt-2 text-sm text-muted">
				{address}
			</p>
		)}
	</div>
</footer>
