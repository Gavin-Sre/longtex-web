---
/** Nav link: href (anchor or URL) and label */
export interface NavLink {
	href: string;
	label: string;
}

interface Props {
	/** Path to logo image (e.g. /ltxlogo-nobg3.png); if not set, shows siteName as text */
	logoSrc?: string;
	/** Site name (used as logo alt and fallback if no logo) */
	siteName?: string;
	/** Links shown in the nav bar — matches original longtex.co.th structure */
	navLinks?: NavLink[];
}

const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

const { logoSrc = `${baseUrl}ltxlogo-nobg3.png`, siteName = "Longtex Rubber Industry", navLinks = [
	{ href: baseUrl, label: "HOME" },
	{ href: `${baseUrl}#about`, label: "ABOUT" },
	{ href: `${baseUrl}products/`, label: "PRODUCTS" },
	{ href: `${baseUrl}products/#papp`, label: "APPLICATIONS" },
	{ href: `${baseUrl}reference/`, label: "REFERENCE" },
	{ href: `${baseUrl}#contact`, label: "CONTACT" },
] } = Astro.props;
---

<!-- Sticky top bar: logo + nav links (matches original longtex.co.th) -->
<header class="sticky top-0 z-100 border-b border-white/10 bg-bg/95 py-3 backdrop-blur-md">
	<nav class="mx-auto flex max-w-[1100px] items-center justify-between px-4 sm:px-6">
		<a href={baseUrl} class="flex items-center gap-2 text-text no-underline hover:opacity-90">
			<img src={logoSrc} alt={siteName} class="h-12 w-auto" width="160" height="55" />
		</a>
		<div class="flex flex-wrap items-center justify-end gap-4 sm:gap-6">
			{navLinks.map((link) => (
				<a href={link.href} class="text-[0.8125rem] font-medium uppercase tracking-wide text-muted hover:text-text sm:text-[0.9375rem]">
					{link.label}
				</a>
			))}
		</div>
	</nav>
</header>
