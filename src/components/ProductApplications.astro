---
/** Product Applications infographic: central hub + five application cards with dotted connectors. */
interface ApplicationItem {
	title: string;
	description: string;
	icon: "sports" | "packaging" | "socks" | "food" | "medical";
}

const applications: ApplicationItem[] = [
	{
		title: "Sports Industry",
		description: "Ranging from sport garments such as waist straps, compression tights to bungee jumping",
		icon: "sports",
	},
	{
		title: "Packaging",
		description: "Made for braids and cords for multi-purpose uses",
		icon: "packaging",
	},
	{
		title: "Socks Top",
		description: "Smaller counts of rubber threads made for socks",
		icon: "socks",
	},
	{
		title: "Food Industry",
		description: "Food grade rubber for meat netting and chicken loops",
		icon: "food",
	},
	{
		title: "Medical Products",
		description: "Masks and orthopedic knit, woven or stockings",
		icon: "medical",
	},
];
---

<div class="flex flex-wrap items-center justify-center gap-0 p-8 px-4 md:justify-start md:gap-4 md:p-12" data-product-apps>
	<!-- Central circle: dark blue, white text -->
	<div class="app-hub shrink-0 flex h-[140px] w-[140px] items-center justify-center rounded-full bg-[#1e3a5f] p-3 opacity-0 transition-opacity duration-300 md:h-40 md:w-40" aria-hidden="true">
		<span class="text-center text-[0.8125rem] font-bold uppercase leading-tight tracking-wide text-white md:text-sm">Product Applications</span>
	</div>

	<!-- Connectors + cards column -->
	<div class="flex min-w-0 max-w-[520px] flex-1 flex-col gap-4 md:max-w-[560px]">
		{applications.map((item, i) => (
			<div class="app-row flex translate-x-3 items-stretch gap-0 opacity-0" style={`--app-delay: ${i * 0.12}s`}>
				<svg class="mt-2 h-6 w-14 shrink-0 text-slate-500 md:w-[72px]" viewBox="0 0 80 24" fill="none" aria-hidden="true">
					<line x1="0" y1="12" x2="80" y2="12" stroke="currentColor" stroke-width="2" stroke-dasharray="4 6" stroke-linecap="round" />
				</svg>
				<div class="flex min-w-0 flex-1 items-center justify-between gap-4 rounded-xl border border-[#1e3a5f]/10 bg-[#cff0fe] px-5 py-4">
					<div class="min-w-0">
						<h3 class="mb-1 text-base font-bold leading-tight text-slate-900">{item.title}</h3>
						<p class="m-0 text-[0.8125rem] leading-snug text-slate-600">{item.description}</p>
					</div>
					<div class="flex h-10 w-10 shrink-0 items-center justify-center text-[#1e3a5f]" aria-hidden="true">
						{item.icon === "sports" && (
							<svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
								<circle cx="12" cy="12" r="4" />
								<path d="M12 8v8M8 12h8" />
							</svg>
						)}
						{item.icon === "packaging" && (
							<svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
							</svg>
						)}
						{item.icon === "socks" && (
							<svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M7 4v16a1 1 0 0 0 1.5.87L12 18l3.5 2.87A1 1 0 0 0 17 20V4a1 1 0 0 0-1.5-.87L12 6l-3.5-2.87A1 1 0 0 0 7 4z" />
								<path d="M4 6h16" />
							</svg>
						)}
						{item.icon === "food" && (
							<svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="9" />
								<path d="M8 14s1.5 2 4 2 4-2 4-2" />
								<path d="M9 9h.01M15 9h.01M9.5 12a.5.5 0 0 1 1 0M13.5 12a.5.5 0 0 1 1 0" />
							</svg>
						)}
						{item.icon === "medical" && (
							<svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 4v16M4 12h16" />
							</svg>
						)}
					</div>
				</div>
			</div>
		))}
	</div>
</div>

<!-- Only keyframes + is-in-view animation (Tailwind can't do this declaratively) -->
<style>
	@media (prefers-reduced-motion: no-preference) {
		[data-product-apps].is-in-view .app-hub {
			opacity: 1;
			animation: app-fade-in 0.6s ease-out forwards;
		}
		[data-product-apps].is-in-view .app-row {
			animation: app-fade-slide-in 0.5s ease-out forwards;
			animation-delay: var(--app-delay, 0s);
			animation-fill-mode: both;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.app-hub,
		.app-row {
			opacity: 1;
			transform: none;
			animation: none;
		}
	}
	@keyframes app-fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes app-fade-slide-in {
		from { opacity: 0; transform: translateX(0.75rem); }
		to { opacity: 1; transform: translateX(0); }
	}
</style>

<script>
	(function () {
		const el = document.querySelector("[data-product-apps]");
		if (!el) return;
		const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		if (reducedMotion) {
			el.classList.add("is-in-view");
			return;
		}
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) entry.target.classList.add("is-in-view");
				});
			},
			{ rootMargin: "0px 0px -5% 0px", threshold: 0 }
		);
		observer.observe(el);
	})();
</script>
