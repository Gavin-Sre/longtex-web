---
/** Product highlight card with image and overlay (like original longtex.co.th). */
interface Props {
	title: string;
	/** Image path in public (e.g. /silicone.jpg) */
	imageSrc: string;
	/** Alt text for the image */
	imageAlt: string;
	/** Whole card links here (e.g. /products#silicone) */
	href: string;
}

const { title, imageSrc, imageAlt, href } = Astro.props;

const cardClass =
	"group relative block overflow-hidden rounded-xl no-underline text-inherit transition-transform duration-300 ease-out hover:scale-[1.04] hover:shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/90 focus-visible:ring-offset-2 focus-visible:ring-offset-bg";
---

<a href={href} class={cardClass}>
	<img
		src={imageSrc}
		alt={imageAlt}
		class="h-56 w-full object-cover transition-transform duration-300 group-hover:scale-105 sm:h-64"
		width="400"
		height="256"
		loading="lazy"
	/>
	<!-- Bottom overlay: title + description (like original .container .content) -->
	<div class="absolute inset-x-0 bottom-0 bg-black/60 px-4 py-4 text-white backdrop-blur-[2px]">
		<h3 class="mb-2 text-lg font-semibold">{title}</h3>
		<p class="m-0 text-sm leading-[1.6] text-white/90">
			<slot />
		</p>
	</div>
</a>
