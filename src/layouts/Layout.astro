---
/** Tailwind: global styles and theme (design tokens) — must be imported so Vite bundles it */
import "../styles/global.css";

/** Layout props: every page can pass a custom title, optional meta description, and optional keywords */
interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
}

const { title, description = "Longtex Rubber Industry is a leading rubber thread manufacturer in Thailand, supplying high-quality natural latex rubber thread for textile, food, and industrial applications. Trusted global supplier for OEM and export markets.", keywords, ogImage } = Astro.props;

/** Base URL for assets and links; always ends with / so (baseUrl + "file.jpg") works */
const baseUrl = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");

/** Build canonical URL for this page (used for SEO and Open Graph); falls back to longtex.co.th if site not set in config */
const siteOrigin = Astro.site?.href ?? "https://www.longtex.co.th";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);

/** OG image — per-page override or fallback to hero image. Always resolved relative to site root. */
const ogImageUrl = new URL(ogImage ?? "rubber-tapping.jpg", siteOrigin).href;

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": `${siteOrigin}#organization`,
	"name": "Longtex Rubber Industry Co., Ltd.",
	"alternateName": "Longtex",
	"url": siteOrigin,
	"logo": {
		"@type": "ImageObject",
		"url": new URL("ltxlogo-nobg3.png", siteOrigin).href
	},
	"description": "Thailand-based manufacturer of extruded natural rubber threads. ISO certified. Products include silicone-coated, talcum-coated, and food-grade rubber threads for textile, medical, and industrial applications.",
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "121/32 Moo 8 Soi Suksawad 74, Suksawad Rd., Bangkru",
		"addressLocality": "Prapradaeng",
		"addressRegion": "Samutprakarn",
		"postalCode": "10130",
		"addressCountry": "TH"
	},
	"areaServed": "Worldwide",
	"knowsAbout": [
		"Extruded rubber thread manufacturing",
		"Natural latex processing",
		"ISO 9001 certified rubber products",
		"Silicone-coated rubber threads",
		"Food-grade rubber threads",
		"Talcum-coated rubber threads"
	]
};
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Basic document and mobile viewport -->
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta http-equiv="X-UA-Compatible" content="ie=edge" />

		<!-- Favicons: Longtex logo and fallbacks -->
		<link rel="icon" href={`${baseUrl}ltxlogo-nobg3.png`} type="image/png" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="shortcut icon" href={`${baseUrl}favicon.ico`} type="image/x-icon" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO: title, description, keywords (from original longtex.co.th) -->
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph: how the page looks when shared on social (e.g. Facebook, LinkedIn) -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Longtex Rubber Industry Co., Ltd." />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<!-- Twitter / X card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Crawl directives -->
		<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
		<link rel="sitemap" href={`${baseUrl}sitemap-index.xml`} />

		<!-- Organization structured data (site-wide) -->
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

		<!-- Google Fonts: preconnect + preload the primary weight for LCP performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/plusjakartasans/v8/LDIoaomQNQcsA88c7O9yZ4KMCoOg4IA6-91aHEjcWuA_KU7NSg.woff2" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<!-- Google Analytics (gtag.js) — same ID as longtex.co.th -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-G5X1E0EXYF"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-G5X1E0EXYF');
		</script>
	</head>
	<body class="min-h-screen bg-bg font-sans text-text antialiased">
		<!-- Page content is injected here by each page that uses this layout -->
		<slot />
	</body>
</html>
