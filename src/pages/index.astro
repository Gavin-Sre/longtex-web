---
// Base layout wraps this page and provides <head>, meta tags, and Tailwind
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Button from "../components/Button.astro";
import Section from "../components/Section.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Footer from "../components/Footer.astro";
---

<Layout
	title="Longtex Corp — Quality You Can Build On"
	description="Longtex Corp delivers reliable solutions and partnerships. Explore our services and get in touch."
>
	<Header />

	<main>
		<!-- Hero: main headline and primary CTAs above the fold -->
		<section class="flex min-h-[85vh] items-center justify-center px-6 py-16 text-center">
			<div class="max-w-[640px]">
				<h1 class="mb-5 text-[clamp(2.25rem,5vw,3.5rem)] font-bold leading-tight tracking-tight">
					Quality you can build on.
				</h1>
				<p class="mb-8 text-lg leading-[1.65] text-muted">
					Longtex Corp partners with businesses to deliver reliable solutions, trusted expertise, and lasting results.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<Button href="#contact">Get in touch</Button>
					<Button href="#services" variant="secondary">Our services</Button>
				</div>
			</div>
		</section>

		<!-- About: company intro; id="about" is the target for the nav link -->
		<Section id="about" title="Who we are">
			<p class="m-0 text-[1.0625rem] leading-[1.7] text-muted">
				We combine industry experience with a focus on quality and reliability. Whether you need supply chain solutions, manufacturing support, or strategic partnership, we're here to help your business grow.
			</p>
		</Section>

		<!-- Services: three value props in a grid; id="services" for nav -->
		<Section id="services" title="What we do" alt>
			<ul class="mt-8 grid list-none gap-6 p-0 sm:grid-cols-3">
				<ServiceCard title="Supply & sourcing">
					Trusted supply chain and sourcing solutions tailored to your needs.
				</ServiceCard>
				<ServiceCard title="Partnership">
					Long-term partnerships built on transparency and performance.
				</ServiceCard>
				<ServiceCard title="Reliability">
					Consistent quality and delivery you can plan around.
				</ServiceCard>
			</ul>
		</Section>

		<!-- Contact CTA: final call to action; id="contact" for nav and hero button -->
		<Section id="contact" title="Let's work together" center>
			<p class="mx-0 mb-6 mt-0 text-[1.0625rem] leading-[1.7] text-muted">
				Ready to get started? Reach out and we'll get back to you as soon as we can.
			</p>
			<Button href="mailto:contact@longtex.com" size="large">Contact us</Button>
		</Section>
	</main>

	<Footer />
</Layout>
